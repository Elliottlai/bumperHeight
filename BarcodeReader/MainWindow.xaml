<Window x:Class="BarcodeReader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="BarcodeReader" Height="720" Width="1280"
        Closed="Window_Closed">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="250" />
        </Grid.RowDefinitions>

        <!-- 影像顯示 -->
        <Border Grid.Column="0" Grid.Row="0" Background="Black" Margin="4">
            <Image x:Name="ImageDisplay" Stretch="Uniform" />
        </Border>

        <!-- 控制面板 -->
        <StackPanel Grid.Column="1" Grid.Row="0" Margin="4">
            <GroupBox Header="裝置">
                <StackPanel>
                    <Button Content="列舉裝置" Command="{Binding EnumerateDevicesCommand}" Margin="0,2" />
                    <ComboBox ItemsSource="{Binding Devices}"
                              SelectedItem="{Binding SelectedDevice}"
                              DisplayMemberPath="DisplayName"
                              Margin="0,2" />
                    <WrapPanel Margin="0,2">
                        <Button Content="開啟" Command="{Binding OpenDeviceCommand}" Width="80" Margin="0,0,4,0" />
                        <Button Content="關閉" Command="{Binding CloseDeviceCommand}" Width="80" />
                    </WrapPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="採集">
                <StackPanel>
                    <WrapPanel Margin="0,2">
                        <Button Content="開始取像" Command="{Binding StartGrabCommand}" Width="80" Margin="0,0,4,0" />
                        <Button Content="停止取像" Command="{Binding StopGrabCommand}" Width="80" />
                    </WrapPanel>
                    <CheckBox Content="觸發模式" IsChecked="{Binding IsTriggerMode}" Margin="0,4" />
                    <CheckBox Content="軟觸發" IsChecked="{Binding IsSoftTrigger}" Margin="0,2" />
                    <Button Content="執行觸發" Command="{Binding TriggerOnceCommand}" Margin="0,2" />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="參數">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>

                    <TextBlock Text="曝光" Grid.Row="0" VerticalAlignment="Center" Margin="0,2" />
                    <TextBox Text="{Binding ExposureTime, StringFormat=F1}" Grid.Row="0" Grid.Column="1" Margin="4,2" />

                    <TextBlock Text="增益" Grid.Row="1" VerticalAlignment="Center" Margin="0,2" />
                    <TextBox Text="{Binding Gain, StringFormat=F1}" Grid.Row="1" Grid.Column="1" Margin="4,2" />

                    <TextBlock Text="幀率" Grid.Row="2" VerticalAlignment="Center" Margin="0,2" />
                    <TextBox Text="{Binding FrameRate, StringFormat=F1}" Grid.Row="2" Grid.Column="1" Margin="4,2" />

                    <WrapPanel Grid.Row="3" Grid.ColumnSpan="2" Margin="0,4">
                        <Button Content="讀取" Command="{Binding LoadParametersCommand}" Width="60" Margin="0,0,4,0" />
                        <Button Content="套用" Command="{Binding ApplyParametersCommand}" Width="60" />
                    </WrapPanel>
                </Grid>
            </GroupBox>
        </StackPanel>

        <!-- 條碼結果列表 -->
        <DataGrid Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1"
                  ItemsSource="{Binding BarcodeResults}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Margin="4">
            <DataGrid.Columns>
                <DataGridTextColumn Header="條碼類型" Binding="{Binding BarType}" Width="80" />
                <DataGridTextColumn Header="條碼內容" Binding="{Binding Code}" Width="*" />
                <DataGridTextColumn Header="處理時間" Binding="{Binding TotalProcessCost}" Width="80" />
                <DataGridTextColumn Header="演算法耗時" Binding="{Binding AlgoCost}" Width="80" />
                <DataGridTextColumn Header="PPM" Binding="{Binding PPM}" Width="60" />
                <DataGridTextColumn Header="品質" Binding="{Binding OverQuality}" Width="60" />
                <DataGridTextColumn Header="IDR分數" Binding="{Binding IDRScore}" Width="70" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
