<Window x:Class="Slot_Inspection.Views.PositionSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="座標設定"
        Width="440"
        Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <!-- 每列高度統一 32 -->
        <Style x:Key="RowBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Height" Value="32"/>
        </Style>
        <Style x:Key="IndexText" TargetType="TextBlock">
            <Setter Property="Width" Value="110"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Foreground" Value="#444"/>
        </Style>
        <Style x:Key="ValueBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#AAA"/>
        </Style>
        <!-- 奇偶行底色 DataTemplate 在 ItemsControl 中套用 -->
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ TabControl ═══ -->
        <TabControl Grid.Row="0" Margin="10,10,10,0" FontSize="13">

            <!-- ══ Y 軸分頁 ══ -->
            <TabItem Header="Y 軸（25 點）">
                <Grid>
                    <!-- 表頭 -->
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Background="#2E86C1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Slot" Foreground="White" FontWeight="Bold"
                                   VerticalAlignment="Center" Padding="6,0"/>
                        <TextBlock Grid.Column="1" Text="Y 座標 (mm)" Foreground="White" FontWeight="Bold"
                                   VerticalAlignment="Center" Padding="4,0"/>
                    </Grid>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding YPositions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource RowBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                       Style="{StaticResource IndexText}"/>
                                            <TextBox Grid.Column="1" Margin="4,3"
                                                     Text="{Binding Value, UpdateSourceTrigger=PropertyChanged, StringFormat=F3}"
                                                     Style="{StaticResource ValueBox}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ══ ZL 軸分頁（R組 X12 / L組 X13）══ -->
            <TabItem Header="ZL 軸">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- R組 標題 -->
                    <Grid Grid.Row="0" Background="#1E7E5E">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="R組" Foreground="White" FontWeight="Bold"
                                   VerticalAlignment="Center" Padding="6,0"/>
                        <TextBlock Grid.Column="1" Text="座標 (mm)" Foreground="White" FontWeight="Bold"
                                   VerticalAlignment="Center" Padding="4,0"/>
                    </Grid>
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding ZLPositions_R}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource RowBorder}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                   Style="{StaticResource IndexText}"/>
                                        <TextBox Grid.Column="1" Margin="4,3"
                                                 Text="{Binding Value, UpdateSourceTrigger=PropertyChanged, StringFormat=F3}"
                                                 Style="{StaticResource ValueBox}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- L組 標題 -->
                    <Grid Grid.Row="2" Background="#2E5E7E">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="L組" Foreground="White" FontWeight="Bold"
                                   VerticalAlignment="Center" Padding="6,0"/>
                        <TextBlock Grid.Column="1" Text="座標 (mm)" Foreground="White" FontWeight="Bold"
                                   VerticalAlignment="Center" Padding="4,0"/>
                    </Grid>
                    <ItemsControl Grid.Row="3" ItemsSource="{Binding ZLPositions_L}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource RowBorder}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                   Style="{StaticResource IndexText}"/>
                                        <TextBox Grid.Column="1" Margin="4,3"
                                                 Text="{Binding Value, UpdateSourceTrigger=PropertyChanged, StringFormat=F3}"
                                                 Style="{StaticResource ValueBox}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </TabItem>

            <!-- ══ ZR 軸分頁（R組 X12 / L組 X13）══ -->
            <TabItem Header="ZR 軸">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- R組 標題 -->
                    <Grid Grid.Row="0" Background="#7B3FA0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="R組" Foreground="White" FontWeight="Bold"
                                   VerticalAlignment="Center" Padding="6,0"/>
                        <TextBlock Grid.Column="1" Text="座標 (mm)" Foreground="White" FontWeight="Bold"
                                   VerticalAlignment="Center" Padding="4,0"/>
                    </Grid>
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding ZRPositions_R}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource RowBorder}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                   Style="{StaticResource IndexText}"/>
                                        <TextBox Grid.Column="1" Margin="4,3"
                                                 Text="{Binding Value, UpdateSourceTrigger=PropertyChanged, StringFormat=F3}"
                                                 Style="{StaticResource ValueBox}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- L組 標題 -->
                    <Grid Grid.Row="2" Background="#3F5FA0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="L組" Foreground="White" FontWeight="Bold"
                                   VerticalAlignment="Center" Padding="6,0"/>
                        <TextBlock Grid.Column="1" Text="座標 (mm)" Foreground="White" FontWeight="Bold"
                                   VerticalAlignment="Center" Padding="4,0"/>
                    </Grid>
                    <ItemsControl Grid.Row="3" ItemsSource="{Binding ZRPositions_L}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource RowBorder}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                   Style="{StaticResource IndexText}"/>
                                        <TextBox Grid.Column="1" Margin="4,3"
                                                 Text="{Binding Value, UpdateSourceTrigger=PropertyChanged, StringFormat=F3}"
                                                 Style="{StaticResource ValueBox}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </TabItem>

            <!-- ══ 取料位座標分頁 ══ -->
            <TabItem Header="取料位座標">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Background="#2E6BA1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="項目" Foreground="White" FontWeight="Bold"
                                   VerticalAlignment="Center" Padding="6,0"/>
                        <TextBlock Grid.Column="1" Text="座標 (mm)" Foreground="White" FontWeight="Bold"
                                   VerticalAlignment="Center" Padding="4,0"/>
                    </Grid>
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding PickPositions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource RowBorder}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                   Style="{StaticResource IndexText}"/>
                                        <TextBox Grid.Column="1" Margin="4,3"
                                                 Text="{Binding Value, UpdateSourceTrigger=PropertyChanged, StringFormat=F3}"
                                                 Style="{StaticResource ValueBox}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </TabItem>

            <!-- ══ X 軸分頁 ══ -->
            <TabItem Header="X 軸">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Background="#C0660A">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="項目" Foreground="White" FontWeight="Bold"
                                   VerticalAlignment="Center" Padding="6,0"/>
                        <TextBlock Grid.Column="1" Text="座標 (mm)" Foreground="White" FontWeight="Bold"
                                   VerticalAlignment="Center" Padding="4,0"/>
                    </Grid>
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding XPositions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource RowBorder}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                   Style="{StaticResource IndexText}"/>
                                        <TextBox Grid.Column="1" Margin="4,3"
                                                 Text="{Binding Value, UpdateSourceTrigger=PropertyChanged, StringFormat=F3}"
                                                 Style="{StaticResource ValueBox}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- ══ 底部按鈕 ══ -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="10,8,10,10">
            <Button Content="取消" Width="88" Height="32" Margin="0,0,8,0" IsCancel="True"/>
            <Button Content="確認套用" Width="100" Height="32" IsDefault="True"
                    Click="BtnOk_Click"
                    Background="#2E86C1" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
