<Window x:Class="Slot_Inspection.Views.ImageViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="影像預覽"
        Width="900" Height="700"
        WindowStartupLocation="CenterOwner"
        Background="#1A1A1A"
        ResizeMode="CanResizeWithGrip">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 工具列 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#2A2A2A" VerticalAlignment="Center">
            <TextBlock x:Name="TitleText" Foreground="White" FontSize="13" VerticalAlignment="Center" Margin="12,0,20,0"/>
            <Button Content="🔍 +" Click="ZoomIn_Click" Padding="8,2" Margin="2" Background="#444" Foreground="White" BorderBrush="#666"/>
            <Button Content="🔍 −" Click="ZoomOut_Click" Padding="8,2" Margin="2" Background="#444" Foreground="White" BorderBrush="#666"/>
            <Button Content="⟳ 重置" Click="Reset_Click" Padding="8,2" Margin="2" Background="#444" Foreground="White" BorderBrush="#666"/>
            <TextBlock x:Name="ZoomText" Foreground="#AAA" FontSize="12" VerticalAlignment="Center" Margin="12,0,0,0" Text="100%"/>
        </StackPanel>

        <!-- 圖像區域：ScrollViewer 負責拖曳，ScaleTransform 負責縮放 -->
        <Border Grid.Row="1" Background="#111" ClipToBounds="True"
                MouseWheel="ImageBorder_MouseWheel"
                MouseLeftButtonDown="ImageBorder_MouseLeftButtonDown"
                MouseLeftButtonUp="ImageBorder_MouseLeftButtonUp"
                MouseMove="ImageBorder_MouseMove"
                Cursor="Hand">
            <Canvas x:Name="ImageCanvas" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image x:Name="PreviewImage"
                       Stretch="None"
                       RenderOptions.BitmapScalingMode="HighQuality">
                    <Image.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="ScaleT" ScaleX="1" ScaleY="1"/>
                            <TranslateTransform x:Name="TranslateT" X="0" Y="0"/>
                        </TransformGroup>
                    </Image.RenderTransform>
                </Image>
            </Canvas>
        </Border>
    </Grid>
</Window>
