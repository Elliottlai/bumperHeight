<Window x:Class="Slot_Inspection.Views.CropSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="裁切設定"
        Width="480"
        Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <!-- 群組框 -->
        <Style x:Key="GroupStyle" TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <!-- 輸入框 -->
        <Style x:Key="NumBox" TargetType="TextBox">
            <Setter Property="Width" Value="70"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="BorderBrush" Value="#AAA"/>
        </Style>
        <!-- 欄位 Label -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="8,0,2,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 說明 -->
        <TextBlock Grid.Row="0"
                   Text="各相機 ROI 設定：勾選「啟用裁切」後輸入起點(X,Y)與寬高(W,H)，單位為像素。設為 -1 或取消勾選表示不裁切。"
                   FontSize="12"
                   Foreground="#555"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10"/>

        <!-- 四個相機群組 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- C1 -->
                <GroupBox Header="C1（X13=true，Right 相機）" Style="{StaticResource GroupStyle}" BorderBrush="#2E86C1">
                    <StackPanel>
                        <CheckBox Content="啟用裁切" FontSize="13" FontWeight="Normal" Margin="0,0,0,6"
                                  IsChecked="{Binding C1.Enabled}"/>
                        <WrapPanel IsEnabled="{Binding C1.InputEnabled}">
                            <TextBlock Text="X：" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding C1.X, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NumBox}"/>
                            <TextBlock Text="Y：" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding C1.Y, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NumBox}"/>
                            <TextBlock Text="W：" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding C1.W, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NumBox}"/>
                            <TextBlock Text="H：" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding C1.H, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NumBox}"/>
                        </WrapPanel>
                    </StackPanel>
                </GroupBox>

                <!-- C2 -->
                <GroupBox Header="C2（X13=true，Left 相機）" Style="{StaticResource GroupStyle}" BorderBrush="#27AE60">
                    <StackPanel>
                        <CheckBox Content="啟用裁切" FontSize="13" FontWeight="Normal" Margin="0,0,0,6"
                                  IsChecked="{Binding C2.Enabled}"/>
                        <WrapPanel IsEnabled="{Binding C2.InputEnabled}">
                            <TextBlock Text="X：" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding C2.X, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NumBox}"/>
                            <TextBlock Text="Y：" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding C2.Y, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NumBox}"/>
                            <TextBlock Text="W：" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding C2.W, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NumBox}"/>
                            <TextBlock Text="H：" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding C2.H, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NumBox}"/>
                        </WrapPanel>
                    </StackPanel>
                </GroupBox>

                <!-- C3 -->
                <GroupBox Header="C3（X12=true，Right 相機）" Style="{StaticResource GroupStyle}" BorderBrush="#E67E22">
                    <StackPanel>
                        <CheckBox Content="啟用裁切" FontSize="13" FontWeight="Normal" Margin="0,0,0,6"
                                  IsChecked="{Binding C3.Enabled}"/>
                        <WrapPanel IsEnabled="{Binding C3.InputEnabled}">
                            <TextBlock Text="X：" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding C3.X, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NumBox}"/>
                            <TextBlock Text="Y：" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding C3.Y, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NumBox}"/>
                            <TextBlock Text="W：" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding C3.W, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NumBox}"/>
                            <TextBlock Text="H：" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding C3.H, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NumBox}"/>
                        </WrapPanel>
                    </StackPanel>
                </GroupBox>

                <!-- C4 -->
                <GroupBox Header="C4（X12=true，Left 相機）" Style="{StaticResource GroupStyle}" BorderBrush="#8E44AD">
                    <StackPanel>
                        <CheckBox Content="啟用裁切" FontSize="13" FontWeight="Normal" Margin="0,0,0,6"
                                  IsChecked="{Binding C4.Enabled}"/>
                        <WrapPanel IsEnabled="{Binding C4.InputEnabled}">
                            <TextBlock Text="X：" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding C4.X, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NumBox}"/>
                            <TextBlock Text="Y：" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding C4.Y, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NumBox}"/>
                            <TextBlock Text="W：" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding C4.W, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NumBox}"/>
                            <TextBlock Text="H：" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding C4.H, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NumBox}"/>
                        </WrapPanel>
                    </StackPanel>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>

        <!-- 底部按鈕 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="確定" Width="80" Height="30" Margin="0,0,10,0"
                    FontSize="13" IsDefault="True" Click="BtnOk_Click"
                    Background="#2E86C1" Foreground="White" FontWeight="Bold"/>
            <Button Content="取消" Width="80" Height="30"
                    FontSize="13" IsCancel="True"
                    Background="#EEE"/>
        </StackPanel>
    </Grid>
</Window>
