<Window x:Class="Slot_Inspection.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Slot_Inspection"
        xmlns:vm="clr-namespace:Slot_Inspection.ViewModels"
        mc:Ignorable="d"
        Title="Slot Inspection"
        Width="1366"
        Height="780"
        WindowStartupLocation="CenterScreen"
        Background="#D9D9D9"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <Style x:Key="SlotNameCellStyle" TargetType="Border">
            <Setter Property="Background" Value="#00B050"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="0,1,1,1"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsNg}" Value="True">
                    <Setter Property="Background" Value="#E60000"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="SlotNameTemplate">
            <Border Style="{StaticResource SlotNameCellStyle}" Height="20">
                <TextBlock Text="{Binding Name}" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="SlotImageTemplate">
            <Border BorderBrush="#333" BorderThickness="0,0,1,1" Height="74" Background="Black">
                <Grid>
                    <Image Source="{Binding ImageSource}" Stretch="UniformToFill"/>
                    <TextBlock x:Name="ImgPlaceholder" Text="IMG" Foreground="#88FFFFFF" FontSize="11"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding ImageSource}" Value="{x:Null}">
                    <Setter TargetName="ImgPlaceholder" Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="SlotValueTemplate">
            <Border BorderBrush="#333" BorderThickness="0,0,1,1" Height="22" Background="White">
                <TextBlock Text="{Binding Value, StringFormat=F2}" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </DataTemplate>

        <Style x:Key="StateButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="RowTitleCellStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="1,1,1,1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="AreaHeaderBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0,4"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
    </Window.Resources>

    <!-- Viewbox 包住全部內容，最大化時等比例縮放 -->
    <Viewbox Stretch="Uniform">
        <Grid Width="1366" Height="780">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="44"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#EFEFEF" BorderBrush="#999" BorderThickness="1" Margin="12,12,12,8" Padding="18,10">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Left" Text="量測畫面示意" FontSize="34" FontStyle="Italic" FontFamily="Times New Roman" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock DockPanel.Dock="Right" Text="Slot Inspection" Foreground="#2E75B6" FontSize="36" FontWeight="Bold" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- Main content -->
            <Border Grid.Row="1" Background="#F8F8F8" BorderBrush="#444" BorderThickness="1" Margin="12,0,12,0">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Barcode + state -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="460"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" BorderBrush="#333" BorderThickness="1" Padding="12,0">
                            <TextBlock Text="Barcode" VerticalAlignment="Center"/>
                        </Border>

                        <Border Grid.Column="1" BorderBrush="#333" BorderThickness="1">
                            <TextBox Text="{Binding Barcode, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="34"
                                     HorizontalContentAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     BorderThickness="0">
                                <TextBox.InputBindings>
                                    <!-- Enter 鍵觸發條碼確認（手動輸入或讀碼器自動填入後確認） -->
                                    <KeyBinding Key="Return" Command="{Binding ConfirmBarcodeCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                        </Border>

                        <UniformGrid Grid.Column="2" Columns="7" HorizontalAlignment="Stretch" Margin="2,0,0,0">
                            <Button Content="RUN" Style="{StaticResource StateButtonStyle}" Background="#00C853"/>
                            <Button Content="Down" Style="{StaticResource StateButtonStyle}" Background="#F44336"/>
                            <Button Content="IDLE" Style="{StaticResource StateButtonStyle}" Background="#DDDDDD"/>
                            <Button Content="START" Style="{StaticResource StateButtonStyle}" Background="#EEEEEE" Command="{Binding StartCommand}"/>
                            <Button Content="STOP" Style="{StaticResource StateButtonStyle}" Background="#EEEEEE" Command="{Binding StopCommand}"/>
                            <Button Content="{Binding CurrentDate}" Style="{StaticResource StateButtonStyle}" Background="#EEEEEE"/>
                            <Button Content="{Binding CurrentTime}" Style="{StaticResource StateButtonStyle}" Background="#EEEEEE"/>
                        </UniformGrid>
                    </Grid>

                    <Border Grid.Row="1" Grid.ColumnSpan="3" Style="{StaticResource AreaHeaderBorderStyle}">
                        <TextBlock Text="Area A" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Area A Row 1 -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="20"/>
                            <RowDefinition Height="74"/>
                            <RowDefinition Height="22"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource RowTitleCellStyle}">
                            <TextBlock Text="SLOT" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource RowTitleCellStyle}" BorderThickness="1,0,1,1">
                            <TextBlock Text="Image" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource RowTitleCellStyle}" BorderThickness="1,0,1,1">
                            <TextBlock Text="Value" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>

                        <ItemsControl Grid.Row="0" Grid.Column="1" ItemsSource="{Binding AreaA_Row1}" ItemTemplate="{StaticResource SlotNameTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="13"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>

                        <ItemsControl Grid.Row="1" Grid.Column="1" ItemsSource="{Binding AreaA_Row1}" ItemTemplate="{StaticResource SlotImageTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="13"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>

                        <ItemsControl Grid.Row="2" Grid.Column="1" ItemsSource="{Binding AreaA_Row1}" ItemTemplate="{StaticResource SlotValueTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="13"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </Grid>

                    <!-- Area A Row 2 -->
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="20"/>
                            <RowDefinition Height="74"/>
                            <RowDefinition Height="22"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource RowTitleCellStyle}">
                            <TextBlock Text="SLOT" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource RowTitleCellStyle}" BorderThickness="1,0,1,1">
                            <TextBlock Text="Image" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource RowTitleCellStyle}" BorderThickness="1,0,1,1">
                            <TextBlock Text="Value" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>

                        <ItemsControl Grid.Row="0" Grid.Column="1" ItemsSource="{Binding AreaA_Row2}" ItemTemplate="{StaticResource SlotNameTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="12"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>

                        <ItemsControl Grid.Row="1" Grid.Column="1" ItemsSource="{Binding AreaA_Row2}" ItemTemplate="{StaticResource SlotImageTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="12"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>

                        <ItemsControl Grid.Row="2" Grid.Column="1" ItemsSource="{Binding AreaA_Row2}" ItemTemplate="{StaticResource SlotValueTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="12"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>

                        <Border Grid.Row="0" Grid.Column="2" Grid.RowSpan="3" BorderBrush="#333" BorderThickness="1" Background="White">
                            <StackPanel VerticalAlignment="Center" DataContext="{Binding AreaA_Stats}">
                                <TextBlock HorizontalAlignment="Center">
                                    <Run Text="Result: "/><Run Text="{Binding Result}"/>
                                </TextBlock>
                                <TextBlock HorizontalAlignment="Center">
                                    <Run Text="Avg: "/><Run Text="{Binding Avg, StringFormat=F2}"/>
                                </TextBlock>
                                <TextBlock HorizontalAlignment="Center">
                                    <Run Text="Min: "/><Run Text="{Binding Min, StringFormat=F2}"/>
                                </TextBlock>
                                <TextBlock HorizontalAlignment="Center">
                                    <Run Text="Max: "/><Run Text="{Binding Max, StringFormat=F2}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="4" Grid.ColumnSpan="3" Style="{StaticResource AreaHeaderBorderStyle}">
                        <TextBlock Text="Area B" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Area B Row 1 -->
                    <Grid Grid.Row="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="20"/>
                            <RowDefinition Height="74"/>
                            <RowDefinition Height="22"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource RowTitleCellStyle}">
                            <TextBlock Text="SLOT" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource RowTitleCellStyle}" BorderThickness="1,0,1,1">
                            <TextBlock Text="Image" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource RowTitleCellStyle}" BorderThickness="1,0,1,1">
                            <TextBlock Text="Value" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>

                        <ItemsControl Grid.Row="0" Grid.Column="1" ItemsSource="{Binding AreaB_Row1}" ItemTemplate="{StaticResource SlotNameTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="13"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>

                        <ItemsControl Grid.Row="1" Grid.Column="1" ItemsSource="{Binding AreaB_Row1}" ItemTemplate="{StaticResource SlotImageTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="13"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>

                        <ItemsControl Grid.Row="2" Grid.Column="1" ItemsSource="{Binding AreaB_Row1}" ItemTemplate="{StaticResource SlotValueTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="13"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </Grid>

                    <!-- Area B Row 2 -->
                    <Grid Grid.Row="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="20"/>
                            <RowDefinition Height="74"/>
                            <RowDefinition Height="22"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource RowTitleCellStyle}">
                            <TextBlock Text="SLOT" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource RowTitleCellStyle}" BorderThickness="1,0,1,1">
                            <TextBlock Text="Image" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource RowTitleCellStyle}" BorderThickness="1,0,1,1">
                            <TextBlock Text="Value" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>

                        <ItemsControl Grid.Row="0" Grid.Column="1" ItemsSource="{Binding AreaB_Row2}" ItemTemplate="{StaticResource SlotNameTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="12"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>

                        <ItemsControl Grid.Row="1" Grid.Column="1" ItemsSource="{Binding AreaB_Row2}" ItemTemplate="{StaticResource SlotImageTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="12"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>

                        <ItemsControl Grid.Row="2" Grid.Column="1" ItemsSource="{Binding AreaB_Row2}" ItemTemplate="{StaticResource SlotValueTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="12"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>

                        <Border Grid.Row="0" Grid.Column="2" Grid.RowSpan="3" BorderBrush="#333" BorderThickness="1" Background="White">
                            <StackPanel VerticalAlignment="Center" DataContext="{Binding AreaB_Stats}">
                                <TextBlock HorizontalAlignment="Center">
                                    <Run Text="Result: "/><Run Text="{Binding Result}"/>
                                </TextBlock>
                                <TextBlock HorizontalAlignment="Center">
                                    <Run Text="Avg: "/><Run Text="{Binding Avg, StringFormat=F2}"/>
                                </TextBlock>
                                <TextBlock HorizontalAlignment="Center">
                                    <Run Text="Min: "/><Run Text="{Binding Min, StringFormat=F2}"/>
                                </TextBlock>
                                <TextBlock HorizontalAlignment="Center">
                                    <Run Text="Max: "/><Run Text="{Binding Max, StringFormat=F2}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- Bottom tabs -->
            <UniformGrid Grid.Row="2" Columns="12" Margin="12,4,12,4">
                <Button Content="Main" Background="#C6E0B4"/>
                <Button Content="Setting"/>
                <Button Content="IO table"/>
                <Button Content="Result"/>
                <Button Content="Alarm History"/>
                <CheckBox Content="模擬模式"
                          IsChecked="{Binding IsSimulationMode}"
                          VerticalContentAlignment="Center"
                          HorizontalAlignment="Center"
                          FontSize="11"
                          ToolTip="勾選=全模擬(Debug-Sim)，取消=實機模式(可空跑)"/>
                <Button Content="⚙ 初始化"
                        Command="{Binding InitAxesCommand}"
                        Style="{StaticResource StateButtonStyle}"
                        Background="#DAE8FC"
                        FontWeight="Bold"
                        ToolTip="Config + Servo 激磁 + PLC 連線"/>
                <Button Content="🏠 原點賦歸"
                        Command="{Binding HomeCommand}"
                        Style="{StaticResource StateButtonStyle}"
                        Background="#D5E8D4"
                        FontWeight="Bold"
                        ToolTip="所有軸回原點"/>
                <Button Content="🔄 空跑測試"
                        Command="{Binding DryRunCommand}"
                        Style="{StaticResource StateButtonStyle}"
                        Background="#FFF2CC"
                        FontWeight="Bold"
                        ToolTip="依序測試所有軸的移動與到位功能（不觸發相機/光源）"/>
                <Button Content="📷 讀取條碼"
                        Command="{Binding ReadBarcodeCommand}"
                        Style="{StaticResource StateButtonStyle}"
                        Background="#B4C7E7"
                        FontWeight="Bold"
                        ToolTip="Y→491 → 偵測 X12/X13 → 移動 X 軸至讀碼位置"/>
                <Button Content="📍 座標設定"
                        Command="{Binding PositionSettingsCommand}"
                        Style="{StaticResource StateButtonStyle}"
                        Background="#E2EFDA"
                        FontWeight="Bold"
                        ToolTip="調整 Y / X / ZL / ZR / Z安全高度座標"/>
                <Button Content="⏹ STOP"
                        Command="{Binding StopCommand}"
                        Style="{StaticResource StateButtonStyle}"
                        Background="#F4B084"
                        FontWeight="Bold"/>
            </UniformGrid>

            <!-- Footer -->
            <Border Grid.Row="3" Background="#2E86C1" Margin="12,0,12,12">
                <DockPanel Margin="16,0">
                    <TextBlock DockPanel.Dock="Right"
                               Text="Synpower"
                               Foreground="White"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="24"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="White"
                               VerticalAlignment="Center"
                               FontSize="14"
                               TextTrimming="CharacterEllipsis"/>
                </DockPanel>
            </Border>
        </Grid>
    </Viewbox>
</Window>
