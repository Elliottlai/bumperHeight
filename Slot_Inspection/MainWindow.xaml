<Window x:Class="Slot_Inspection.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Slot_Inspection"
        xmlns:vm="clr-namespace:Slot_Inspection.ViewModels"
        mc:Ignorable="d"
        Title="Slot Inspection"
        Width="1366"
        Height="780"
        WindowStartupLocation="CenterScreen"
        Background="#D9D9D9"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <Style x:Key="SlotNameCellStyle" TargetType="Border">
            <Setter Property="Background" Value="#00B050"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="0,1,1,1"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsNg}" Value="True">
                    <Setter Property="Background" Value="#E60000"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="SlotNameTemplate">
            <Border Style="{StaticResource SlotNameCellStyle}" Height="20">
                <TextBlock Text="{Binding Name}" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="SlotImageTemplate">
            <Border BorderBrush="#333" BorderThickness="0,0,1,1" Height="74" Background="Black">
                <Grid>
                    <Image Source="{Binding ImageSource}" Stretch="Uniform"/>
                    <TextBlock x:Name="ImgPlaceholder" Text="IMG" Foreground="#88FFFFFF" FontSize="11"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding ImageSource}" Value="{x:Null}">
                    <Setter TargetName="ImgPlaceholder" Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="SlotValueTemplate">
            <Border BorderBrush="#333" BorderThickness="0,0,1,1" Height="22" Background="White">
                <TextBlock Text="{Binding Value, StringFormat=F2}" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </DataTemplate>

        <!-- 每個 Slot 卡片：Slot編號 + 圖像 + 數値全包在一起 -->
        <DataTemplate x:Key="SlotCardTemplate">
            <Border BorderBrush="#333" BorderThickness="0,1,1,1" Height="116">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="22"/>
                    </Grid.RowDefinitions>

                    <!-- SLOT 名稱 -->
                    <Border Grid.Row="0" Style="{StaticResource SlotNameCellStyle}" BorderThickness="0,0,0,1">
                        <TextBlock Text="{Binding Name}" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- 圖像（可點擊放大） -->
                    <Border Grid.Row="1" BorderBrush="#333" BorderThickness="0,0,0,1" Background="Black"
                            Cursor="Hand" Tag="{Binding}">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.OpenImageViewerCommand,
                                RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                        </Border.InputBindings>
                        <Grid>
                            <Image Source="{Binding ImageSource}" Stretch="Uniform"/>
                            <TextBlock x:Name="ImgPlaceholder" Text="IMG" Foreground="#88FFFFFF" FontSize="11"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                            <!-- 放大提示 icon -->
                            <TextBlock Text="🔍" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                       Foreground="#AAFFFFFF" Margin="0,0,2,2"
                                       Visibility="{Binding ImageSource, Converter={x:Null}}"/>
                        </Grid>
                    </Border>

                    <!-- Value -->
                    <Border Grid.Row="2" Background="White">
                        <TextBlock Text="{Binding Value, StringFormat=F2}" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding ImageSource}" Value="{x:Null}">
                    <Setter TargetName="ImgPlaceholder" Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <Style x:Key="StateButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="RowTitleCellStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="1,1,1,1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="AreaHeaderBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0,4"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
    </Window.Resources>

    <!-- Viewbox 包住全部內容，最大化時等比例縮放 -->
    <Viewbox Stretch="Uniform">
        <Grid Width="1366" Height="780">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="44"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#EFEFEF" BorderBrush="#999" BorderThickness="1" Margin="12,12,12,8" Padding="18,10">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Left" Text="聯策科技" FontSize="34" FontStyle="Italic" FontFamily="Times New Roman" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock DockPanel.Dock="Right" Text="Slot Inspection" Foreground="#2E75B6" FontSize="36" FontWeight="Bold" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- Main content -->
            <Border Grid.Row="1" Background="#F8F8F8" BorderBrush="#444" BorderThickness="1" Margin="12,0,12,0">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Barcode + state -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="460"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" BorderBrush="#333" BorderThickness="1" Padding="12,0">
                            <TextBlock Text="Barcode" VerticalAlignment="Center"/>
                        </Border>

                        <Border Grid.Column="1" BorderBrush="#333" BorderThickness="1">
                            <TextBox Text="{Binding Barcode, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="34"
                                     HorizontalContentAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     BorderThickness="0">
                                <TextBox.InputBindings>
                                    <!-- Enter 鍵觸發條碼確認（手動輸入或讀碼器自動填入後確認） -->
                                    <KeyBinding Key="Return" Command="{Binding ConfirmBarcodeCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                        </Border>

                        <Grid Grid.Column="2" Margin="2,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="⚙ 初始化"
                                    Command="{Binding InitAxesCommand}"
                                    Style="{StaticResource StateButtonStyle}"
                                    Background="#DAE8FC" FontSize="11" Padding="10,4"
                                    FontWeight="Bold" ToolTip="Config + Servo 激磁 + PLC 連線"/>
                            <Button Grid.Column="1" Content="🏠 原點賦歸"
                                    Command="{Binding HomeCommand}"
                                    Style="{StaticResource StateButtonStyle}"
                                    Background="#D5E8D4" FontSize="11" Padding="10,4"
                                    FontWeight="Bold" ToolTip="所有軸回原點"/>
                            <Button Grid.Column="2" Content="▶ RUN"
                                    Command="{Binding RunCommand}"
                                    Style="{StaticResource StateButtonStyle}"
                                    Background="#C6EFCE" FontSize="11" Padding="16,4"
                                    FontWeight="Bold" ToolTip="執行主流程：逐 Slot 移動、取像、存圖"/>
                            <Button Grid.Column="3" Content="⏹ STOP"
                                    Command="{Binding StopCommand}"
                                    Style="{StaticResource StateButtonStyle}"
                                    Background="#FFCCCC" FontSize="11" Padding="16,4"
                                    FontWeight="Bold"/>
                            <Button Grid.Column="4" Content="{Binding CurrentDate}" Style="{StaticResource StateButtonStyle}" Background="#EEEEEE"/>
                            <Button Grid.Column="5" Content="{Binding CurrentTime}" Style="{StaticResource StateButtonStyle}" Background="#EEEEEE"/>
                        </Grid>
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="6*"/>
                            <ColumnDefinition Width="4*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Area A 標題 -->
                        <Border Grid.Column="0" Background="#2E75B6" BorderBrush="#1A4E8A" BorderThickness="1" Margin="0,2,4,2">
                            <TextBlock Text="Area A" FontSize="15" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <!-- Area A Stats -->
                        <Border Grid.Column="1" BorderBrush="#333" BorderThickness="1" Background="#F0F4FA" Margin="0,2,0,2">
                            <UniformGrid Columns="4" DataContext="{Binding AreaA_Stats}">
                                <Border BorderBrush="#BCC" BorderThickness="0,0,1,0">
                                    <StackPanel VerticalAlignment="Center" Margin="4,3">
                                        <TextBlock Text="Result" FontSize="9" Foreground="#666" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding Result}" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border BorderBrush="#BCC" BorderThickness="0,0,1,0">
                                    <StackPanel VerticalAlignment="Center" Margin="4,3">
                                        <TextBlock Text="Avg" FontSize="9" Foreground="#666" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding Avg, StringFormat=F2}" FontSize="13" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border BorderBrush="#BCC" BorderThickness="0,0,1,0">
                                    <StackPanel VerticalAlignment="Center" Margin="4,3">
                                        <TextBlock Text="Min" FontSize="9" Foreground="#666" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding Min, StringFormat=F2}" FontSize="13" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border>
                                    <StackPanel VerticalAlignment="Center" Margin="4,3">
                                        <TextBlock Text="Max" FontSize="9" Foreground="#666" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding Max, StringFormat=F2}" FontSize="13" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </Border>
                    </Grid>

                    <!-- Area A Row 1+2 -->
                    <Grid Grid.Row="2" Margin="0,2,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 左側固定標籤欄（兩排各一組） -->
                        <Border Grid.Column="0" BorderBrush="#333" BorderThickness="1,1,1,1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="116"/>
                                    <RowDefinition Height="116"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="20"/>
                                        <RowDefinition Height="74"/>
                                        <RowDefinition Height="22"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="White" BorderBrush="#333" BorderThickness="0,0,0,1">
                                        <TextBlock Text="SLOT" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Row="1" Background="White" BorderBrush="#333" BorderThickness="0,0,0,1">
                                        <TextBlock Text="Image" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Row="2" Background="White" BorderBrush="#333" BorderThickness="0,0,0,1">
                                        <TextBlock Text="Value" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                </Grid>

                                <Grid Grid.Row="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="20"/>
                                        <RowDefinition Height="74"/>
                                        <RowDefinition Height="22"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="White" BorderBrush="#333" BorderThickness="0,0,0,1">
                                        <TextBlock Text="SLOT" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Row="1" Background="White" BorderBrush="#333" BorderThickness="0,0,0,1">
                                        <TextBlock Text="Image" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Row="2" Background="White">
                                        <TextBlock Text="Value" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Slot 卡片列表，13個一排自動換行 -->
                        <ItemsControl Grid.Column="1" ItemsSource="{Binding AreaA_Row1}" ItemTemplate="{StaticResource SlotCardTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="13"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </Grid>

                    <!-- Area B 標頭 -->
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="6*"/>
                            <ColumnDefinition Width="4*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Area B 標題 -->
                        <Border Grid.Column="0" Background="#548235" BorderBrush="#375623" BorderThickness="1" Margin="0,2,4,2">
                            <TextBlock Text="Area B" FontSize="15" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <!-- Area B Stats -->
                        <Border Grid.Column="1" BorderBrush="#333" BorderThickness="1" Background="#F0F4FA" Margin="0,2,0,2">
                            <UniformGrid Columns="4" DataContext="{Binding AreaB_Stats}">
                                <Border BorderBrush="#BCC" BorderThickness="0,0,1,0">
                                    <StackPanel VerticalAlignment="Center" Margin="4,3">
                                        <TextBlock Text="Result" FontSize="9" Foreground="#666" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding Result}" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border BorderBrush="#BCC" BorderThickness="0,0,1,0">
                                    <StackPanel VerticalAlignment="Center" Margin="4,3">
                                        <TextBlock Text="Avg" FontSize="9" Foreground="#666" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding Avg, StringFormat=F2}" FontSize="13" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border BorderBrush="#BCC" BorderThickness="0,0,1,0">
                                    <StackPanel VerticalAlignment="Center" Margin="4,3">
                                        <TextBlock Text="Min" FontSize="9" Foreground="#666" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding Min, StringFormat=F2}" FontSize="13" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border>
                                    <StackPanel VerticalAlignment="Center" Margin="4,3">
                                        <TextBlock Text="Max" FontSize="9" Foreground="#666" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding Max, StringFormat=F2}" FontSize="13" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </Border>
                    </Grid>

                    <!-- Area B Row 1+2 -->
                    <Grid Grid.Row="5" Margin="0,2,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 左側固定標籤欄（兩排各一組） -->
                        <Border Grid.Column="0" BorderBrush="#333" BorderThickness="1,1,1,1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="116"/>
                                    <RowDefinition Height="116"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="20"/>
                                        <RowDefinition Height="74"/>
                                        <RowDefinition Height="22"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="White" BorderBrush="#333" BorderThickness="0,0,0,1">
                                        <TextBlock Text="SLOT" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Row="1" Background="White" BorderBrush="#333" BorderThickness="0,0,0,1">
                                        <TextBlock Text="Image" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Row="2" Background="White" BorderBrush="#333" BorderThickness="0,0,0,1">
                                        <TextBlock Text="Value" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                </Grid>

                                <Grid Grid.Row="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="20"/>
                                        <RowDefinition Height="74"/>
                                        <RowDefinition Height="22"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="White" BorderBrush="#333" BorderThickness="0,0,0,1">
                                        <TextBlock Text="SLOT" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Row="1" Background="White" BorderBrush="#333" BorderThickness="0,0,0,1">
                                        <TextBlock Text="Image" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Row="2" Background="White">
                                        <TextBlock Text="Value" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Slot 卡片列表，13個一排自動換行 -->
                        <ItemsControl Grid.Column="1" ItemsSource="{Binding AreaB_Row1}" ItemTemplate="{StaticResource SlotCardTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="13"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </Grid>
                </Grid>
            </Border>

            <!-- Bottom tabs -->
            <UniformGrid Grid.Row="2" Columns="11" Margin="12,4,12,4">
                <Button Content="Main" Background="#C6E0B4" FontSize="11" Padding="4,4"/>
                <Button Content="Setting" FontSize="11" Padding="4,4"/>
                <Button Content="IO table" FontSize="11" Padding="4,4"/>
                <Button Content="Result" FontSize="11" Padding="4,4"/>
                <Button Content="Alarm History" FontSize="11" Padding="4,4"/>
                <CheckBox Content="模擬模式"
                          IsChecked="{Binding IsSimulationMode}"
                          VerticalContentAlignment="Center"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          FontSize="11"
                          ToolTip="勾選=全模擬(Debug-Sim)，取消=實機模式(可空跑)"/>
                <CheckBox Content="⏱ ZL/ZR 安定延遲"
                          IsChecked="{Binding EnableAxisSettleDelay}"
                          VerticalContentAlignment="Center"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          FontSize="11"
                          ToolTip="勾選：ZL/ZR 到位後等待 150 ms 再拍照，防止機械振動造成影像模糊"/>
                <Button Content="📷 讀取條碼"
                        Command="{Binding ReadBarcodeCommand}"
                        Style="{StaticResource StateButtonStyle}"
                        Background="#B4C7E7" FontSize="11" Padding="4,4"
                        FontWeight="Bold"
                        ToolTip="Y→491 → 偵測 X12/X13 → 移動 X 軸至讀碼位置"/>
                <Button Content="📦 移至取料位"
                        Command="{Binding MoveToPickPositionCommand}"
                        Style="{StaticResource StateButtonStyle}"
                        Background="#FFF2CC" FontSize="11" Padding="4,4"
                        FontWeight="Bold"
                        ToolTip="Y 軸移動到取料位置的座標"/>
                <Button Content="📍 座標設定"
                        Command="{Binding PositionSettingsCommand}"
                        Style="{StaticResource StateButtonStyle}"
                        Background="#E2EFDA" FontSize="11" Padding="4,4"
                        FontWeight="Bold"
                        ToolTip="調整 Y / X / ZL / ZR / Z安全高度座標"/>
                <Button Content="✂ 裁切設定"
                        Command="{Binding CropSettingsCommand}"
                        Style="{StaticResource StateButtonStyle}"
                        Background="#FCE4EC" FontSize="11" Padding="4,4"
                        FontWeight="Bold"
                        ToolTip="設定 C1~C4 各相機的影像裁切 ROI（X/Y/W/H）"/>
            </UniformGrid>

            <!-- Footer -->
            <Border Grid.Row="3" Background="#2E86C1" Margin="12,0,12,12">
                <DockPanel Margin="16,0">
                    <TextBlock DockPanel.Dock="Right"
                               Text="Synpower"
                               Foreground="White"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="24"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="White"
                               VerticalAlignment="Center"
                               FontSize="14"
                               TextTrimming="CharacterEllipsis"/>
                </DockPanel>
            </Border>
        </Grid>
    </Viewbox>
</Window>
