<Window x:Class="CameraLightTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CameraLightTest"
        mc:Ignorable="d"
        Title="相機 + 光源 測試工具" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen" Closed="Window_Closed">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="160"/>
        </Grid.RowDefinitions>

        <!-- Row 0: 初始化區 -->
        <GroupBox Grid.Row="0" Header="初始化" Padding="8" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="光源 COM:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox x:Name="TxtLightCom" Width="70" Text="COM7" VerticalAlignment="Center"/>
                <TextBlock Text="  相機:" VerticalAlignment="Center" Margin="8,0,4,0"/>
                <ComboBox x:Name="CmbCamera" Width="140" VerticalAlignment="Center"/>
                <Button x:Name="BtnInit" Content="初始化全部" Margin="16,0,0,0" Padding="12,4"
                        Click="BtnInit_Click"/>
                <TextBlock x:Name="TxtInitStatus" VerticalAlignment="Center" Margin="12,0,0,0"
                           Foreground="Gray" Text="尚未初始化"/>
            </StackPanel>
        </GroupBox>

        <!-- Row 1: 控制區 -->
        <GroupBox Grid.Row="1" Header="控制面板" Padding="8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 光源控制 -->
                <StackPanel Grid.Column="0" Orientation="Vertical" Margin="0,0,20,0">
                    <TextBlock Text="光源控制" FontWeight="Bold" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="通道:" VerticalAlignment="Center" Width="45"/>
                        <TextBox x:Name="TxtLightChannel" Width="40" Text="1" VerticalAlignment="Center"/>
                        <TextBlock Text="  亮度:" VerticalAlignment="Center" Margin="8,0,4,0"/>
                        <Slider x:Name="SliderIntensity" Width="150" Minimum="0" Maximum="100"
                                Value="80" VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="1"/>
                        <TextBlock x:Name="TxtIntensityValue" Text="80%" VerticalAlignment="Center"
                                   Width="40" Margin="6,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <Button x:Name="BtnLightOn" Content="開光源" Width="70" Padding="4"
                                Click="BtnLightOn_Click" IsEnabled="False"/>
                        <Button x:Name="BtnLightOff" Content="關光源" Width="70" Padding="4"
                                Margin="8,0,0,0" Click="BtnLightOff_Click" IsEnabled="False"/>
                    </StackPanel>
                </StackPanel>

                <!-- 相機控制 -->
                <StackPanel Grid.Column="1" Orientation="Vertical" Margin="20,0,20,0">
                    <TextBlock Text="相機控制" FontWeight="Bold" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="曝光 (μs):" VerticalAlignment="Center" Width="70"/>
                        <TextBox x:Name="TxtExposure" Width="80" Text="5000" VerticalAlignment="Center"/>
                        <Button x:Name="BtnSetExposure" Content="設定" Margin="8,0,0,0" Padding="8,2"
                                Click="BtnSetExposure_Click" IsEnabled="False"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <Button x:Name="BtnCapture" Content="📷 拍照 (開光→拍→關光→存檔)" Padding="10,4"
                                Click="BtnCapture_Click" IsEnabled="False" FontSize="13"/>
                    </StackPanel>
                </StackPanel>

                <!-- 存檔路徑 -->
                <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Text="存檔路徑" FontWeight="Bold" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="TxtSavePath" Width="180" Text="D:\CameraLightTest"
                                 VerticalAlignment="Center"/>
                        <Button Content="..." Margin="4,0,0,0" Padding="6,2"
                                Click="BtnBrowse_Click"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Row 2: 影像預覽 -->
        <GroupBox Grid.Row="2" Header="影像預覽" Padding="4">
            <Border Background="#FF1E1E1E" CornerRadius="4">
                <Image x:Name="ImgPreview" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
            </Border>
        </GroupBox>

        <!-- Row 3: Log -->
        <GroupBox Grid.Row="3" Header="Log" Padding="4" Margin="0,8,0,0">
            <TextBox x:Name="TxtLog" IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="11"
                     Background="#FF1E1E1E" Foreground="#FFDCDCDC" TextWrapping="NoWrap"/>
        </GroupBox>
    </Grid>
</Window>
