<UserControl x:Class="DeltaAxis_RS485.Views.AxisControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800" >
 
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12">           
            <DockPanel Margin="0,0,0,12">
                <TextBlock Text="{Binding DisplayName}" FontSize="18" FontWeight="Bold"
                           VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Ellipse Width="12" Height="12" Margin="0,0,6,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="Gray" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="LimeGreen" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <Button Content="連線" Command="{Binding ConnectCommand}" 
                            Width="60" Margin="0,0,4,0" />
                    <Button Content="斷線" Command="{Binding DisconnectCommand}"
                            Width="60" />
                </StackPanel>
            </DockPanel>

            <!-- 伺服控制 -->
            <GroupBox Header="伺服控制" Margin="0,0,0,10">
                <StackPanel Margin="8">
                    <WrapPanel Margin="0,0,0,8">
                        <TextBlock Text="激磁: " />
                        <TextBlock Text="{Binding IsServoOn}" FontWeight="Bold" Margin="0,0,16,0" />
                        <TextBlock Text="警報: " />
                        <TextBlock Text="{Binding HasAlarm}" FontWeight="Bold" Margin="0,0,16,0" />
                        <TextBlock Text="Abs OK: " />
                        <TextBlock Text="{Binding AbsOk}" FontWeight="Bold" />
                    </WrapPanel>
                    <WrapPanel>
                        <Button Content="Servo ON" Command="{Binding ServoOnCommand}"
                                Width="90" Margin="0,0,4,0" />
                        <Button Content="Servo OFF" Command="{Binding ServoOffCommand}"
                                Width="90" Margin="0,0,4,0" />
                        <Button Content="清除警報" Command="{Binding ClearAlarmCommand}"
                                Width="90" Margin="0,0,4,0" />
                        <Button Content="重建 Abs" Command="{Binding RebuildAbsOriginCommand}"
                                Width="90" Margin="0,0,4,0" />
                        <Button Content="刷新" Command="{Binding RefreshStatusCommand}" Width="70" />
                    </WrapPanel>
                </StackPanel>
            </GroupBox>

            <!-- 運動參數 -->
            <GroupBox Header="運動參數" Margin="0,0,0,10">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="140" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28" />
                        <RowDefinition Height="28" />
                        <RowDefinition Height="28" />
                        <RowDefinition Height="34" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="速度 (rpm)" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" />
                    <TextBox Text="{Binding TargetSpeed, UpdateSourceTrigger=PropertyChanged}"
                             Grid.Row="0" Grid.Column="1" Margin="0,2" />

                    <TextBlock Text="加速 (ms)" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" />
                    <TextBox Text="{Binding AccelerationTime, UpdateSourceTrigger=PropertyChanged}"
                             Grid.Row="1" Grid.Column="1" Margin="0,2" />

                    <TextBlock Text="減速 (ms)" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" />
                    <TextBox Text="{Binding DecelerationTime, UpdateSourceTrigger=PropertyChanged}"
                             Grid.Row="2" Grid.Column="1" Margin="0,2" />

                    <TextBlock Text="延遲 (ms)" Grid.Row="0" Grid.Column="3" VerticalAlignment="Center" />
                    <TextBox Text="{Binding DelayTime, UpdateSourceTrigger=PropertyChanged}"
                             Grid.Row="0" Grid.Column="4" Margin="0,2" />

                    <TextBlock Text="PUU/mm" Grid.Row="1" Grid.Column="3" VerticalAlignment="Center" />
                    <TextBox Text="{Binding PuuPerMm, UpdateSourceTrigger=PropertyChanged}"
                             Grid.Row="1" Grid.Column="4" Margin="0,2" />

                    <TextBlock Text="逾時 (ms)" Grid.Row="2" Grid.Column="3" VerticalAlignment="Center" />
                    <TextBox Text="{Binding InPositionTimeout, UpdateSourceTrigger=PropertyChanged}"
                             Grid.Row="2" Grid.Column="4" Margin="0,2" />

                    <Button Content="寫入驅動器" Command="{Binding ApplySettingsCommand}"
                            Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                            Width="120" HorizontalAlignment="Left" />
                </Grid>
            </GroupBox>

            <!-- 定位控制 -->
            <GroupBox Header="定位控制">
                <StackPanel Margin="8">
                    <WrapPanel Margin="0,0,0,8">
                        <TextBlock Text="位置 (mm): " />
                        <TextBlock Text="{Binding CurrentPositionMm, StringFormat=F3}"
                                   FontWeight="Bold" Margin="0,0,16,0" />
                        <TextBlock Text="多圈 (PUU): " />
                        <TextBlock Text="{Binding MultiTurnPosition}" FontWeight="Bold" Margin="0,0,16,0" />
                        <TextBlock Text="單圈 (PUU): " />
                        <TextBlock Text="{Binding SingleTurnPosition}" FontWeight="Bold" />
                    </WrapPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="目標 (mm):" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBox Text="{Binding TargetPositionMm, UpdateSourceTrigger=PropertyChanged}"
                                 Width="120" Margin="0,0,8,0" />
                        <Button Content="移動" Command="{Binding MoveToPositionCommand}"
                                Width="80" Margin="0,0,4,0" />
                        <Button Content="刷新位置" Command="{Binding RefreshStatusCommand}" Width="80" />
                    </StackPanel>
                </StackPanel>
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>